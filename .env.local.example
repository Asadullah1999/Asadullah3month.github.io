# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — create these in your Stripe Dashboard → Products
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# n8n Webhook
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/

# Groq AI (for AI Meal Scanner, AI Nutritionist Chat, Smart Grocery List)
# FREE tier: 30 RPM, 14,400 req/day — Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# FatSecret Platform API — food database (14M+ foods including Indian foods)
# Sign up at: https://platform.fatsecret.com/api/Default.aspx
# Free tier: 500 req/day per method
FATSECRET_CLIENT_ID=your_fatsecret_client_id
FATSECRET_CLIENT_SECRET=your_fatsecret_client_secret

# Nutritionix API — natural language food parsing ("2 roti and dal" → macros)
# Sign up at: https://developer.nutritionix.com
# Free tier: 500 req/day
NUTRITIONIX_APP_ID=your_nutritionix_app_id
NUTRITIONIX_APP_KEY=your_nutritionix_app_key

# RapidAPI key — used for ExerciseDB (1,300+ exercises with muscle groups & GIFs)
# Sign up at: https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
# Free tier: 500 req/month
RAPIDAPI_KEY=your_rapidapi_key

# App
NEXT_PUBLIC_SITE_URL=https://fahmifit.com
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
