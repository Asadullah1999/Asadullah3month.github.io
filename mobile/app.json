{
  "expo": {
    "name": "FahmiFit",
    "slug": "fahmifitapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fahmifitapp",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4332"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fahmifitapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1B4332"
      },
      "package": "com.fahmifitapp",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Allow FahmiFit to access your camera to scan barcodes and food photos." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow FahmiFit to access your photos to analyze meal photos." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
