{
  "expo": {
    "name": "FahmiFit",
    "slug": "fahmifit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fahmifit.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FahmiFit uses the camera to scan meals and barcodes for nutrition tracking.",
        "NSPhotoLibraryUsageDescription": "FahmiFit accesses your photos to analyze meal images.",
        "NSMicrophoneUsageDescription": "FahmiFit may use the microphone for voice input features."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "package": "com.fahmifit.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "Allow FahmiFit to access your camera" }],
      ["expo-barcode-scanner", { "cameraPermission": "Allow FahmiFit to access camera for barcode scanning" }],
      ["expo-image-picker", { "photosPermission": "Allow FahmiFit to access your photos" }],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
